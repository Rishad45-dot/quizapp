                                "content": "Fatigue"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "d8d6b3a28ac34a698d3d5f64d1032999",
                                "content": "Malaise"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
