                                "isSelected": "0",
                                "id": "ff46c6e2221b4fb5849aa4dc884149e7",
                                "content": "Suctioning the client as needed"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "908af27714414cc4a519ef64074f3336",
                                "content": "Encouraging coughing every 2 hours"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "7efc855dd50045d3965326dc9146b743",
                                "content": "Placing the bed in low-Fowler's position"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "fd6b2ff9bc6a4b0692de63658be77b35",
                                "content": "Supporting the neck incision when the client coughs"
