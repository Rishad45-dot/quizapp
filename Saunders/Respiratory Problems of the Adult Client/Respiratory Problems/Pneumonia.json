                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "c76bb7d4b42e4ea4b177ebd6918878a3",
                                "content": "Place the client in semi-Fowler's position"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "ef18dbb09d604e08813f628b386ddba4",
                                "content": "Allow the client frequent rest breaks during the meal"
                            }
                        ],
