                                "isSelected": "0",
                                "id": "4ac996212a594df3b1f19dc0cd037300",
                                "content": "Dry air"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "49bfdd3412084013ab24129081774f50",
                                "content": "Clean air"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "9d06860fb4474b8da338d52f63af89ae",
                                "content": "Exercise"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "8b43a6d4886c4bf4887701a6bcc435b9",
                                "content": "Rest and sleep"
                            },
                            {
