                                "isSelected": "0",
                                "id": "c4f65344d420432798d909dcddceb540",
                                "content": "Dyspnea"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "c339508a908f419f8bcda3c3e2be60df",
                                "content": "Bradypnea"
                            },
