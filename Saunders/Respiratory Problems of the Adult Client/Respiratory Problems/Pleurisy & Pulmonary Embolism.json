                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "22740827bb2bb6f888aa2227e71db9f8",
                                "content": "Asthma"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "69656299a661a56dc381889d270958f7",
                                "content": "Pleurisy"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "ea15258d13f660f86ff894154ccde025",
                                "content": "Emphysema"
