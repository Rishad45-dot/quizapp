                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "aa21920deec1458aac140f069fc67bcb",
                                "content": "Hot, flushed feeling"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "fe391e4d8e4d4f2cbd08b0dbb22982a8",
                                "content": "Sudden chills and fever"
                            },
