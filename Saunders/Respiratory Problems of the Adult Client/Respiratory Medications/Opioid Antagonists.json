                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "21d0ebbf4dcd424ab21b76a933319ffb",
                                "content": "Nasogastric tube"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "baa15a7106734ed1a7ff56ea8642784f",
                                "content": "Paracentesis tray"
                            },
