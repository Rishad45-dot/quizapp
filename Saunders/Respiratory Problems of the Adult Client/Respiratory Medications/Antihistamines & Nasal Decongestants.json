                                "id": "eb665b17bfb94a579865fd9702d85cd5",
                                "content": "Take it on an empty stomach."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "6c013acd12474e17844810a35366eff8",
                                "content": "Avoid activities requiring mental alertness."
