                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "3045e227fdb24fdd80112d952502613f",
                                "content": "To examine the testicles while lying down"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "680b02a339cd4f469e13a25f7f5c6852",
                                "content": "That the best time for the examination is after a shower"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "5d5bdb9bf3d14dec88eb174bd8645b9d",
                                "content": "To gently feel the testicle with one finger to feel for a growth"
