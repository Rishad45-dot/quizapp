                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "ccb19516b40846f1adf987d7ecf2e3db",
                                "content": "Headache"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "294268947f7a4c0ca4e1ed3a411f2b9b",
                                "content": "Dysphagia"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "2de1f6efcd45436a83b1814a6f2fac8c",
                                "content": "Constipation"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "1a0806fae5084b5b804d33cf73c1e8c8",
                                "content": "Electrocardiographic changes"
                            }
                        ],
