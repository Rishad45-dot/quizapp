                                "content": "Fever"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "f268902b9b4a4d85b7024b715538d083",
                                "content": "Weight loss"
                            },
                            {
