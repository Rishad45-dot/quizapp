                                "isSelected": "0",
                                "id": "2e1b269c36354f1bbdabb4c395b1573f",
                                "content": "Measure the client's current weight and height."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "bbb7f63245fa4efb961208142ec9ef77",
                                "content": "Ask the client to share current weight and height."
                            }
                        ],
                        "extJson": {
