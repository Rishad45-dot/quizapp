                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "303ec235312c4f63b181bcc0fad47c8f",
                                "content": "Measure the client's abdominal girth."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "100f58f50ffc4d78a52e0440b9fecd31",
                                "content": "Calculate the client's body mass index."
                            },
