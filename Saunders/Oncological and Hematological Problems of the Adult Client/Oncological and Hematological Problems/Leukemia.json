                                "isSelected": "0",
                                "id": "d16f0c71741446298655351c2f3ca117",
                                "content": "Increased uric acid level"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "26379a10e2b84bd0b4866ca30cf8f15f",
                                "content": "Decreased leukocyte count"
