                                "isSelected": "0",
                                "id": "23196bb9632949769f969b1213531c8d",
                                "content": "Anemia"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "9293aebb2878437d82bab6b731f5aa86",
