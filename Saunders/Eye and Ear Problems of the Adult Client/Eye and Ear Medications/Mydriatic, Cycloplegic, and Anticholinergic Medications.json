                                    "content": "Call the surgeon, as this medication will further constrict the operative pupil."
                                },
                                {
                                    "isRight": "1",
                                    "userAnswer": "",
                                    "isSelected": "0",
                                    "id": "1e30208fc7314c3986e1e0933be342de",
