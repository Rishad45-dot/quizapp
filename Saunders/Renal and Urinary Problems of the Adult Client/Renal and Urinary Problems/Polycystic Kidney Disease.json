                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "d4e4420ed4754004ad1af50d2b17ccdc",
                                "content": "Administer as-needed analgesic."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "86ad9ae65d36474483863e2b020cd8e0",
