                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "63f82a69e84242cdadff0052a4e18dc1",
                                "content": "Generalized skin rash"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "6d0b27d2a2644ccabfc2a72b7eb4ebc6",
                                "content": "Cardiac dysrhythmia"
