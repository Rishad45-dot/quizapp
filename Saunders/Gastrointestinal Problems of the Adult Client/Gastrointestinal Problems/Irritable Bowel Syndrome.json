                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "60288a230cbd454abf83399ffa22d4fc",
                                "content": "“I cannot have anything to eat or drink besides water for at least 12 hours before the test.”"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "9eea3c06d72141f8afa919be8787e95e",
                                "content": "“Additional breath samples may be taken every 15 minutes for a time period ranging from 1 to 5 hours.”"
