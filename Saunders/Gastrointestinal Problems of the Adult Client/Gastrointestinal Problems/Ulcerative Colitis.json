                                    "isSelected": "0",
                                    "id": "9dcb1ca761fc40ad958b2285142bba68",
                                    "content": "The client is experiencing early signs of ischemic bowel."
                                },
                                {
                                    "isRight": "0",
                                    "userAnswer": "",
                                    "isSelected": "0",
                                    "id": "2a65cddda4884227be135a9f26409136",
                                    "content": "The client should not have the nasogastric tube removed."
                                },
                                {
                                    "isRight": "0",
