                                "id": "b3ddd732e7e8405f8ce6a90d3f702270",
                                "content": "Shortness of breath on exertion"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "ecaa59a2b20b4f90a40ab75504c3eed2",
                                "content": "Red tongue that is smooth and sore"
