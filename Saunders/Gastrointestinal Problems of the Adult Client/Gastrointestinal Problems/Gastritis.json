                        "optionList": [
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "d0cc4e4b931d42e9a7dc6154195e9378",
                                "content": "Dyspnea"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "cbce1b40bbe948558e315a19182dc481",
                                "content": "Dusky mucous membranes"
                            },
