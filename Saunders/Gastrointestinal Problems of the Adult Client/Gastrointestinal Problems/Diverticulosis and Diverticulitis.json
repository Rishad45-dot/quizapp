                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "0214fe6ff7864f50b1ba7d7fb9d94c79",
                                "content": "Increased white blood cell count, increased hemoglobin, increased hematocrit"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "24f5767e4cec47b7a36e26e7290d5fff",
                                "content": "Decreased white blood cell count, increased hemoglobin, increased hematocrit"
                            },
                            {
