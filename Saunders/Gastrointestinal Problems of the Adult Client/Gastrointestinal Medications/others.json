                                "id": "5de79917fb5b4e84b1efaaacb874d14f",
                                "content": "Prevent fluid retention and ascites."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "90578cea11114960967182557d3481e4",
                                "content": "Destroy normal bacteria found in the bowel."
