                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "14af14725d27443893db269a1e9c59a5",
                                "content": "\"This medication will prevent a stroke.\""
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "b47a976f431b43a1a72d84d0d814fd34",
                                "content": "\"This medication will prevent a heart attack.\""
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "1b4e4e73d5254389b5a5dff102dc6b15",
                                "content": "\"This medication will help keep my blood pressure down.\""
                            },
