                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "72d3d30c1f7349adb0e112b50fbf0aab",
                                "content": "Hemorrhage"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "c1b9f5832bfc4bb89548184ab90c2c44",
                                "content": "Edema of the residual limb"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "13ad464f54804a0f9968df5068364d35",
                                "content": "Slight redness of the incision"
