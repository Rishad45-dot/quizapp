                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "4a681fd1699443519d4513c3f2942bb4",
                                "content": "Apply ice to the site."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "c5ed2f80279e4d6cb4e175993836bdce",
                                "content": "Call the primary health care provider (PHCP)."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "0f5b58029569441dba3937b08d8d5f2b",
                                "content": "Rewrap the residual limb with an elastic compression bandage."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "bd0ef17b84b540139328dc36203fdeaa",
                                "content": "Apply a dry, sterile dressing and elevate the residual limb on one pillow."
                            }
