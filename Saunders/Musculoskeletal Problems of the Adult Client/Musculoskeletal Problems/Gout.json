                                "content": "Renal ultrasound"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "701aec2303484246a3b3c41037dc4f2d",
                                "content": "Serum uric acid level"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
