                                "content": "Irreversible kidney damage is likely to occur."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "fa697955c0ec4f83a3f894a88ee2229c",
                                "content": "The original symptoms will be greatly intensified."
                            },
                            {
                                "isRight": "0",
