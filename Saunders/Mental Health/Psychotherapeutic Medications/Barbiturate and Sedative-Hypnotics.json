                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "72e4773a9ac84b8e950a7dec67fb3fbb",
                                "content": "Barbiturate use commonly results in a rush of energy."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "f10a750c9789406db1ab50453a9e7580",
                                "content": "Barbiturate abuse is the cause of many drug overdose deaths."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
