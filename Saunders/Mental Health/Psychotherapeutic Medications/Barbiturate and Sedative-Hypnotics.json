                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "320bd4958ae7455b8ab347d6f0f05d6a",
                                "content": "\"I take the medication just after my evening meal.\""
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "59bc062a934e424488d12244a17fa095",
                                "content": "\"I wait until bedtime and take the medication with a snack.\""
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "caaa7e778eb34e2f8168701250623b9a",
