                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "0e665a85404940f393079d0b9fa334bd",
                                "content": "Escort the client to a private, low-stimulus room."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "a2f83c56f3d645cbabfe0715b80dc45f",
                                "content": "Engage the client in a nonthreatening conversation."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "dc71112981074007b00f535a4606b928",
                                "content": "Allow the client to pace unless the behavior becomes aggressive."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "cfd5e54c9f4d4e70b8548bf86cb1c181",
                                "content": "Share the observation with the client so that the behavior can be recognized."
