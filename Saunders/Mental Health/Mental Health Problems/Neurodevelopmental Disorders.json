                                "id": "6371e3019d7d428fbbe6441f22538a21",
                                "content": "Promote complete independence in the client."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "a96bbff42b3747068bf87853c6ac5c99",
                                "content": "Strengthen the client's ability to manage stress."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
