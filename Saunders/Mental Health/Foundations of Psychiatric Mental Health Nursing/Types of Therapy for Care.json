                                "isSelected": "0",
                                "id": "0bdda1effae247a8bdab809339cb934f",
                                "content": "The nurse managing an aggressive client"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "bcd6b5e3688d47a38f4649ad677375e7",
                                "content": "The psychiatrist prescribing antidepressant medication"
