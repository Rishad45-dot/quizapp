                                "isSelected": "0",
                                "id": "3021782c59ea41a08f970362b2056b7b",
                                "content": "Developing toxicity"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "637ad4713ec741ca841df0c2d3c44121",
                                "content": "A harmless side effect of the medication"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "777bc104b76b4f2399f2802d88b06294",
                                "content": "A result of taking the medication with milk"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "b620a0b86de04c439ac30dd22e237612",
                                "content": "A sign of interaction with another medication"
                            }
                        ],
