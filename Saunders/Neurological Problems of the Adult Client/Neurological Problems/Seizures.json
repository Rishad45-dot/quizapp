                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "48ec657790f343819e3530f21ede0652",
                                "content": "Postictal status"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "4d543d82f8414d90bfb9a48864a6a9f4",
                                "content": "Duration of the seizure"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "076ee15d34284a5fa56c8e69c24ec3c9",
                                "content": "Changes in pupil size or eye deviation"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "70b9e7744d414cc1bcd43e83acfff16f",
                                "content": "Seizure progression and type of movements"
