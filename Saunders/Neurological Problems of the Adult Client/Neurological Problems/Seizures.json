                                "isSelected": "0",
                                "id": "5eb13d6964384749b9341fb50bee58a0",
                                "content": "Loosening restrictive clothing"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "dff92514966b499eace12037a3e0d743",
                                "content": "Restraining the client's limbs"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "d61502dc44ef47cc9047986c92e6e9dc",
                                "content": "Removing the pillow and raising padded side rails"
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "bf648ba07c154ab696bd757c265d7f52",
                                "content": "Positioning the client to the side, if possible, with the head flexed forward"
