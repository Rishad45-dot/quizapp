                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "9205a01d2c6143f39120869da7ff49e3",
                                "content": "Refrain from smoking alone."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "79d137451a334c9385747193926169fb",
                                "content": "Take all prescribed medications on time."
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "cdb33216cf9f48adbb1b26eb5e246973",
                                "content": "Have the spouse nearby when showering."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "2710fbc9de014782b390c66a0e99fda9",
                                "content": "Drink alcohol in small amounts and only on weekends."
                            }
                        ],
