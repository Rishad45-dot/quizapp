                                "id": "211da7118a9541d7b426fa558711db29",
                                "content": "Temperature of 102° F (39.8° C)"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "255b158e78fb4929868880305b413930",
                                "content": "Blood urea nitrogen (BUN) of 20 mg/dL (7.1 mmol/L)"
