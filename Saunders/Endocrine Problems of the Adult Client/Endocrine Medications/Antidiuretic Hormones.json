                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "9b7cba1f56844690b824f13ffa4f5f45",
                                "content": "\"It decreases muscle contractions.\""
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "1cc4885be27d4439ba869641a8431d48",
                                "content": "\"It opens up my blood vessels.\""
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "c6968a0a4b6b452bb220c9cda2291f44",
                                "content": "\"It prevents me from ‘peeing' so much.\""
                            },
                            {
                                "isRight": "0",
