                                "isSelected": "0",
                                "id": "88b933a9c14e4ded9f13370d9739217d",
                                "content": "Dilute the medication in 8 oz of water."
                            },
                            {
                                "isRight": "1",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "fea9e72671e1414b9ab8600f3a91fee5",
                                "content": "Report the symptom to the primary health care provider (PHCP)."
