                        "mark": "0",
                        "collectionState": "0"
                    },
                    {
                        "optionList": [
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "a9e5b669e8a5489899d69006239e9a19",
                                "content": "\"It replaces thyroid hormone.\""
                            },
                            {
                                "isRight": "0",
