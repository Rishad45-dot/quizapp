                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "93b0dcd36fd84c7fbf02f4b78dfb1435",
                                "content": "Calcium chloride"
                            },
                            {
                                "isRight": "0",
                                "userAnswer": "",
                                "isSelected": "0",
                                "id": "306b0a680f7542fb892ad84b0d54e7b9",
                                "content": "Calcium gluconate"
